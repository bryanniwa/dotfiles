### Navigation Helpers
alias ... "cd ../.."
alias .... "cd ../../.."

### Exa mappings
abbr l eza
abbr ls eza
abbr ll "eza -l"
abbr la "eza -la"
abbr lt "eza -T"

### Docker Compose abbreviations
abbr dc docker compose

### Git abbreviations
abbr gswm git switch \(__git.default_branch\)
abbr gswd git switch develop
abbr gc!! git commit --amend --no-edit
abbr gca!! git commit --amend --no-edit --all

### JJ abbreviations
abbr jla jj log -r ::
abbr jld jj log -T builtin_log_detailed
abbr jlda jj log -r :: -T builtin_log_detailed

## Chezmoi abbreviation
abbr cm chezmoi

